\contentsline {subsection}{\numberline {4.12.23}Por qué cualquier usuario autenticado puede crear eventos}{75}{subsection.4.12.23}%
\contentsline {subsection}{\numberline {4.12.24}Por qué los roles de administrador y moderador no se han unificado}{75}{subsection.4.12.24}%
\contentsline {subsection}{\numberline {4.12.25}Por qué se ha implementado scraping en lugar de usar únicamente APIs oficiales}{76}{subsection.4.12.25}%
\contentsline {subsection}{\numberline {4.12.26}Por qué se usa Cloudinary para el almacenamiento de imágenes}{77}{subsection.4.12.26}%
\contentsline {subsection}{\numberline {4.12.27}Por qué la aplicación ofrece modo claro y modo oscuro}{77}{subsection.4.12.27}%
\contentsline {subsection}{\numberline {4.12.28}Por qué se usa Firebase Authentication en lugar de autenticación propia}{78}{subsection.4.12.28}%
\contentsline {subsection}{\numberline {4.12.29}Por qué se usa React Native con Expo y no otra tecnología móvil}{78}{subsection.4.12.29}%
\contentsline {subsection}{\numberline {4.12.30}Por qué se usa NestJS como framework de backend}{79}{subsection.4.12.30}%
