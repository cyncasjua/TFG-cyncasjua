\contentsline {subsection}{\numberline {4.12.5}Por qué el administrador solo gestiona roles y categorías}{68}{subsection.4.12.5}%
\contentsline {subsection}{\numberline {4.12.6}Por qué el chat incluye persistencia y no es solo en tiempo real}{68}{subsection.4.12.6}%
\contentsline {subsection}{\numberline {4.12.7}Por qué los eventos privados se aprueban automáticamente}{69}{subsection.4.12.7}%
\contentsline {subsection}{\numberline {4.12.8}Por qué los eventos privados usan un enlace UUID en lugar de una lista de control de acceso}{69}{subsection.4.12.8}%
\contentsline {subsection}{\numberline {4.12.9}Por qué los eventos recurrentes generan instancias independientes en base de datos}{70}{subsection.4.12.9}%
\contentsline {subsection}{\numberline {4.12.10}Por qué se usa PostGIS con tipo \textit {geography} y SRID 4326}{70}{subsection.4.12.10}%
\contentsline {subsection}{\numberline {4.12.11}Por qué hay tres schedulers de notificaciones independientes}{71}{subsection.4.12.11}%
\contentsline {subsection}{\numberline {4.12.12}Por qué el scraping se ejecuta a las 3:00 AM}{71}{subsection.4.12.12}%
\contentsline {subsection}{\numberline {4.12.13}Por qué el cron job es externo y no interno al backend}{71}{subsection.4.12.13}%
\contentsline {subsection}{\numberline {4.12.14}Flujo del sistema de scraping}{72}{subsection.4.12.14}%
\contentsline {subsection}{\numberline {4.12.15}Por qué los scrapers siguen el patrón estrategia con interfaz \texttt {IScraper}}{72}{subsection.4.12.15}%
\contentsline {subsection}{\numberline {4.12.16}Por qué se usan contextos de React en lugar de una librería de estado global}{73}{subsection.4.12.16}%
\contentsline {subsection}{\numberline {4.12.17}Por qué la preferencia de tema se guarda en \texttt {AsyncStorage} y no en el servidor}{73}{subsection.4.12.17}%
\contentsline {subsection}{\numberline {4.12.18}Por qué la conexión WebSocket se autentica en el \textit {handshake} y no por mensaje}{73}{subsection.4.12.18}%
